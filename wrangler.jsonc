{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "structured-input",
  "compatibility_date": "2026-01-28",
  "compatibility_flags": ["nodejs_compat"],
  "main": "worker/index.ts",
  "rules": [
    {
      "type": "Text",
      "globs": ["**/*.html"],
      "fallthrough": true
    }
  ],
  "kv_namespaces": [
    {
      "binding": "IMAGES",
      "id": "638dba4e956f4444be4dc3a89a3e4b81"
    }
  ]
}
